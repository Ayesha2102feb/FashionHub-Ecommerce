<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Admin Dashboard</title>

	<link href="~/dist/css/styles.css" rel="stylesheet" />
	<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/js/all.min.js"></script>
</head>

<body class="sb-nav-fixed">

	<!-- TOP NAVBAR -->
	<nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">

		<!-- LOGO -->
		<a class="navbar-brand ps-3" href="@Url.Action("Index", "Admin")">
			Admin Panel
		</a>

		<!-- TOGGLE -->
		<ul class="navbar-nav ms-auto me-3">
			<li class="nav-item">
				<a class="nav-link text-danger" href="@Url.Action("Logout", "Admin")">
					<i class="fas fa-sign-out-alt me-1"></i> Logout
				</a>
			</li>
		</ul>
	</nav>

	<div id="layoutSidenav">

		<!-- SIDEBAR -->
		<div id="layoutSidenav_nav">
			<nav class="sb-sidenav accordion sb-sidenav-light">

				<div class="sb-sidenav-menu">
					<div class="nav">

						<!-- DASHBOARD -->
						<a class="nav-link" href="@Url.Action("Index", "Admin")">
							<i class="fas fa-tachometer-alt"></i> Dashboard
						</a>

						<!-- CUSTOMERS -->
						<a class="nav-link" href="@Url.Action("fetchCustomer", "Admin")">
							<i class="fas fa-users"></i> Customers
						</a>

						<!-- CATEGORIES -->
						<a class="nav-link" href="@Url.Action("fetchCategory", "Admin")">
							<i class="fas fa-list"></i> Categories
						</a>

						<!-- PRODUCTS -->
						<a class="nav-link" href="@Url.Action("fetchProduct", "Admin")">
							<i class="fas fa-box"></i> Products
						</a>

						<!-- ORDERS -->
						<a class="nav-link" href="@Url.Action("Orders", "Admin")">
							<i class="fas fa-shopping-cart"></i> Orders
						</a>

						<!-- CART -->
						<a class="nav-link" href="@Url.Action("fetchCart", "Admin")">
							<i class="fas fa-cart-plus"></i> Cart
						</a>

						<!-- FEEDBACK -->
						<a class="nav-link" href="@Url.Action("fetchFeedback", "Admin")">
							<i class="fas fa-comments"></i> Feedback
						</a>

					</div>
				</div>

				<div class="sb-sidenav-footer">
					<div class="small">Logged in as:</div>
					Admin
				</div>

			</nav>
		</div>

		<!-- MAIN CONTENT -->
		<div id="layoutSidenav_content">
			<main class="p-3">
				@RenderBody()
			</main>

			<footer class="py-3 bg-light mt-auto">
				<div class="container-fluid text-center small text-muted">
					© 2026 Isha Siddiqa | Fashion Hub Admin Panel
				</div>
			</footer>
		</div>

	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/dist/js/scripts.js"></script>

</body>
</html>
