<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<title>FashionHub</title>
	<meta content="width=device-width, initial-scale=1.0" name="viewport">

	<link href="~/website/img/favicon.ico" rel="icon" />

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

	<!-- Icons -->
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

	<!-- CSS -->
	<link href="~/website/css/style.min.css" rel="stylesheet" />

	<style>
		body {
			font-family: 'Roboto', sans-serif;
		}

		.logo-text {
			font-size: 28px;
			font-weight: 700;
		}

			.logo-text span {
				color: #D19C97;
			}

		.cart-badge {
			position: absolute;
			top: -5px;
			right: -8px;
			background: red;
			color: white;
			font-size: 12px;
			padding: 2px 6px;
			border-radius: 50%;
		}

		.nav-link:hover {
			color: #D19C97 !important;
		}

		.header-wrapper {
			display: flex;
			align-items: center;
			justify-content: space-between;
			flex-wrap: wrap;
		}

		.search-box {
			flex: 1;
			min-width: 250px;
			max-width: 600px;
			margin: 0 20px;
		}

		.header-right {
			display: flex;
			align-items: center;
			gap: 12px;
		}

		.welcome-box {
			display: flex;
			align-items: center;
			gap: 6px;
			padding: 5px 10px;
			border-radius: 20px;
			font-size: 13px;
			background: linear-gradient(135deg, #f8f9fa, #e9ecef);
			max-width: 140px;
		}

			.welcome-box span {
				max-width: 80px;
				overflow: hidden;
				white-space: nowrap;
				text-overflow: ellipsis;
				display: inline-block;
			}

			.welcome-box i {
				background: #D19C97;
				color: white;
				padding: 5px;
				border-radius: 50%;
				font-size: 12px;
			}

		.header-right .btn {
			padding: 6px 12px;
			font-size: 13px;
		}

		@@media (max-width: 768px) {
			.search-box {
				margin: 10px 0;
				width: 100%;
			}

			.welcome-box {
				display: none;
			}
		}
	</style>
</head>

<body>

	@{
		var customerId = Context.Session.GetString("customer_id");
		var userName = Context.Session.GetString("user_email");
	}

	<!-- HEADER -->
	<div class="container-fluid bg-light py-3 px-xl-5">
		<div class="header-wrapper">

			<div class="logo-text">
				<a href="/" class="text-decoration-none">
					FASHION<span>HUB</span>
				</a>
			</div>

			<div class="search-box">
				<form asp-controller="Customer" asp-action="Search" method="get">
					<div class="input-group">
						<input type="text" name="query" class="form-control" placeholder="Search for products..." required>
						<div class="input-group-append">
							<button class="input-group-text bg-primary text-white">
								<i class="fa fa-search"></i>
							</button>
						</div>
					</div>
				</form>
			</div>

			<div class="header-right">

				<div style="position:relative;">
					<a href="@Url.Action("fetchCart", "Customer")" class="btn px-2">
						<i class="fas fa-shopping-cart text-dark" style="font-size:20px;"></i>
					</a>
					<span class="cart-badge">
						@(ViewBag.CartCount ?? 0)
					</span>
				</div>

				@if (!string.IsNullOrEmpty(userName))
				{
					<div class="welcome-box">
						<i class="fa fa-user"></i>
						<span title="@userName">
							@userName.Split('@')[0]
						</span>
					</div>
				}

				@if (string.IsNullOrEmpty(customerId))
				{
					<a href="@Url.Action("CustomerLogin", "Customer")" class="btn btn-outline-primary btn-sm">
						<i class="fa fa-user"></i> Login
					</a>
				}
				else
				{
					<div class="btn-group">
						<button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
							Account
						</button>
						<div class="dropdown-menu dropdown-menu-end">
							<a class="dropdown-item" href="@Url.Action("CustomerProfile", "Customer")">Profile</a>
							<a class="dropdown-item" href="@Url.Action("CustomerLogout", "Customer")">Logout</a>
						</div>
					</div>
				}

			</div>
		</div>
	</div>

	<!-- NAVBAR -->
	<div class="container-fluid bg-dark mb-4">
		<div class="row px-xl-5">
			<div class="col-lg-12">
				<nav class="navbar navbar-expand-lg navbar-dark bg-dark py-2 px-0">

					<button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
						<span class="navbar-toggler-icon"></span>
					</button>

					<div class="collapse navbar-collapse" id="navbarCollapse">
						<div class="navbar-nav mr-auto">
							<a href="/" class="nav-item nav-link active">Home</a>
							<a href="/Customer/fetchAllProducts" class="nav-item nav-link">Shop</a>
							<a href="@Url.Action("MyOrders", "Order")" class="nav-item nav-link">My Orders</a>
							<a href="@Url.Action("feedback", "Customer")" class="nav-item nav-link">Contact</a>
						</div>
					</div>

				</nav>
			</div>
		</div>
	</div>

	<!-- BODY -->
	<div class="container">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<!-- FOOTER -->
	<div class="container-fluid bg-dark text-white mt-5 pt-5">
		<div class="row px-xl-5">
			<div class="col-md-6 mb-4">
				<h5>FashionHub</h5>
				<p>Your one-stop shop for trendy fashion.</p>
			</div>

			<div class="col-md-6 mb-4 text-md-right">
				<p>Email: support@fashionhub.com</p>
				<p>Phone: +91 9876543210</p>
			</div>
		</div>

		<div class="text-center py-3 border-top">
			© 2026 FashionHub. All Rights Reserved.
		</div>
	</div>

	<!-- JS -->
	<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/website/js/main.js"></script>

</body>
</html>
