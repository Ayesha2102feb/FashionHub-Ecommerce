@model List<EcomWebsite.Models.Category>

<div class="container-fluid pt-5">

	<h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4">
		<span class="bg-secondary pr-3">Categories</span>
	</h2>

	<div class="row px-xl-5 pb-3">

		@if (Model != null && Model.Any())
		{
			foreach (var cat in Model)
			{
				<div class="col-lg-3 col-md-4 col-sm-6 pb-3">

					<a href="@Url.Action("ProductByCategory", "Customer", new { id = cat.category_id })"
					   class="text-decoration-none">

						<div class="cat-item d-flex align-items-center bg-light p-3 rounded shadow-sm">

							<!-- ✅ CATEGORY IMAGE -->
							

							<!-- CATEGORY NAME -->
							<div class="pl-3">
								<h6 class="mb-1 text-dark">@cat.category_name</h6>
								<small class="text-muted">Explore Products</small>
							</div>

						</div>

					</a>

				</div>
			}
		}
		else
		{
			<div class="col-12 text-center text-danger">
				<h5>No categories available</h5>
			</div>
		}

	</div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<script>
	document.querySelector('input[name="imageFile"]').addEventListener('change', function (e) {
		const file = e.target.files[0];
		if (file) {
			const preview = document.getElementById('preview');
			preview.src = URL.createObjectURL(file);
			preview.style.display = 'block';
		}
	});
</script>
