@{
	ViewData["Title"] = "Home";
	Layout = "~/Views/Shared/_Layout.cshtml";

	var userName = Context.Session.GetString("user_email");
}

<style>
	.section-title {
		font-weight: 600;
		letter-spacing: 2px;
	}

	/* HERO */
	.hero-text h1 {
		font-size: 50px;
		font-weight: 700;
	}

	/* FEATURES */
	.feature-box {
		transition: 0.3s;
	}

		.feature-box:hover {
			background: #f8f9fa;
			transform: translateY(-5px);
		}

	/* CATEGORY */
	.category-card {
		position: relative;
		overflow: hidden;
		cursor: pointer;
	}

		.category-card img {
			transition: 0.4s;
			height: 350px;
			width: 100%;
			object-fit: cover;
		}

		.category-card:hover img {
			transform: scale(1.1);
		}

	.category-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0,0,0,0.4);
		opacity: 0;
		transition: 0.3s;
	}

	.category-card:hover .category-overlay {
		opacity: 1;
	}

	/* PRODUCTS */
	.product-card {
		transition: 0.3s;
	}

		.product-card:hover {
			transform: translateY(-8px);
			box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
		}
</style>

<!-- Welcome -->

