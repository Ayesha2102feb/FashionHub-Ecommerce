
@{
	ViewData["Title"] = "feedback";
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Get In Touch With Us</h2>
<div class="container mt-3">

<div class="row">
	<div class="col-md-5">
		<form method="post">
				<input type="text" placeholder="Enter Your Full Name" name="user_name" class="form-control mb-4"/>
				<textarea placeholder="Enter Your Message" name="user_message" class="form-control mb-4"></textarea>
				<input type="submit" class="btn btn-warning btn-block"/>
		</form>
	</div>
	<div class="col-md-1"></div>
		<div class="col-md-6">
			<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3619.313992521624!2d67.14924997296895!3d24.88726914418874!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3eb339999415e0c3%3A0x36742eee0fd9c291!2sAptech%20Metro%20Star%20Gate!5e0!3m2!1sen!2sin!4v1772791921771!5m2!1sen!2sin"
					width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy">
			</iframe>
		</div>
</div>
	<h6 class="text-success">@TempData["message"]</h6>
</div>
