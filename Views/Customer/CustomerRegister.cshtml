@{
	Layout = null;
}

<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>Register - MultiShop</title>
	<meta content="width=device-width, initial-scale=1.0" name="viewport">

	<!-- Favicon -->
	<link href="~/website/img/favicon.ico" rel="icon" />

	<!-- Google Font -->
	<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

	<!-- Font Awesome -->
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

	<!-- Template CSS -->
	<link href="~/website/css/style.min.css" rel="stylesheet" />

	<style>
		body {
			margin: 0;
			padding: 0;
			height: 100vh;
			display: flex;
			justify-content: center;
			align-items: center;
			background: url('/website/img/regi.jpg') no-repeat center center;
			background-size: cover;
			font-family: 'Roboto', sans-serif;
		}

		.register-card {
			width: 420px;
			background: #ffffff;
			padding: 40px;
			border-radius: 10px;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
		}

			.register-card h3 {
				text-align: center;
				margin-bottom: 30px;
				font-weight: 600;
			}

		.form-control {
			height: 45px;
			border-radius: 5px;
		}

		.btn-register {
			background-color: #D19C97;
			color: #fff;
			width: 100%;
			height: 45px;
			border-radius: 5px;
			font-weight: 500;
		}

			.btn-register:hover {
				background-color: #c48883;
			}

		.register-link {
			text-align: center;
			margin-top: 15px;
		}

			.register-link a {
				color: #D19C97;
				font-weight: 500;
			}

				.register-link a:hover {
					text-decoration: underline;
				}
	</style>
</head>

<body>

	<div class="register-card">
		<h3>REGISTRATION FORM</h3>

		
			<form asp-action="CustomerRegister" asp-controller="Customer" method="post">

			<div class="form-group mb-3">
				<input type="text" name="customer_name" class="form-control" placeholder="Enter your name" required />
			</div>
			<div class="form-group mb-3">
				<input type="text" name="customer_phone" class="form-control" placeholder="Enter your Phone no" required />
			</div>
			<div class="form-group mb-3">
				<input type="email" name="customer_email" class="form-control" placeholder="Enter your Email-id" required />
			</div>


			<div class="form-group mb-3">
				<input type="password" name="customer_password" class="form-control" placeholder="Enter your Password" required />
			</div>
			

			<button type="submit" class="btn btn-register">
		      Sign Up
			</button>

			<div class="register-link">
				<a href="@Url.Action("CustomerLogin", "Customer")">
					Already have an account? Login
				</a>
			</div>

		</form>
	</div>

	<!-- JS Files -->
	<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
	<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
	<script src="~/website/js/main.js"></script>

</body>
</html>
